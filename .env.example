# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — Google PageSpeed Insights API key for higher rate limits
# Without a key: ~25 requests / 100 seconds (sufficient for dev/MVP)
# Get one free at: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=
